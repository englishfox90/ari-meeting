docs/*.gif
docs/*.mov

# Third-party reference sample projects (Apple docs samples, vendor examples).
# Read-only reference for patterns during the Swift migration — never built or shipped.
# The README is tracked so the convention is documented; everything else is ignored.
/samples/*
!/samples/README.md

