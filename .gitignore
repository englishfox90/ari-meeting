# --- Private meeting-derived data + regenerable eval outputs (NEVER commit) ---
# These hold real transcript text, generated summaries, and meeting titles pulled
# from the local app DB. All regenerate from the DB via each tool's extract script.
tools/stt-eval/results/
tools/prompt-harness/runs/
tools/prompt-harness/fixtures/cache/
tools/prompt-harness/fixtures/manifest.json
